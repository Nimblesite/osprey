// Allocate + traverse many short-lived binary trees — allocation/memory stress.
type Tree = Leaf | Node(Tree, Tree)

fn make(d) = match d {
    0 => Node(Leaf, Leaf)
    _ => Node(make(d - 1), make(d - 1))
}
fn check(t) = match t {
    Leaf       => 0
    Node(l, r) => 1 + check(l) + check(r)
}

print("${range(0, 1200) |> fold(0, |acc, _| => acc + check(make(13)))}")
