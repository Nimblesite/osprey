{
  "name": "osprey-website",
  "version": "0.2.0",
  "description": "Official website for the Osprey Programming Language",
  "main": "index.js",
  "scripts": {
    "start": "npm run update-playground && npm run copy-spec && npm run generate-docs && eleventy --serve",
    "dev": "npm run update-playground && npm run copy-spec && npm run generate-docs && eleventy --serve --watch",
    "build": "npm run update-playground && npm run copy-spec && npm run generate-docs && eleventy",
    "copy-spec": "node scripts/copy-spec.js",
    "generate-docs": "bash scripts/generate-docs.sh && npm run add-ml-twins",
    "add-ml-twins": "python3 scripts/add-ml-twins.py",
    "update-playground": "node scripts/update-playground.js",
    "build:wasm": "cd .. && make wasm-site",
    "clean": "rm -rf _site",
    "test": "npm run build:wasm && playwright test",
    "test:e2e": "npm run build:wasm && playwright test",
    "test:headed": "playwright test --headed",
    "test:report": "playwright show-report"
  },
  "keywords": [
    "osprey",
    "programming-language",
    "website",
    "eleventy"
  ],
  "author": "Christian Findlay",
  "license": "MIT",
  "devDependencies": {
    "@11ty/eleventy": "^3.1.2",
    "@11ty/eleventy-plugin-syntaxhighlight": "^5.0.1",
    "@playwright/test": "^1.61.0",
    "luxon": "^3.6.1",
    "markdown-it": "^14.1.0",
    "markdown-it-anchor": "^9.2.0"
  },
  "dependencies": {
    "eleventy-plugin-techdoc": "^0.2.0"
  }
}
