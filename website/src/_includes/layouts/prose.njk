---
layout: layouts/base.njk
---
{# Shared layout for every long-form page (docs, spec, blog posts, status).
   One prose design for all of them — see src/css/components.css `.prose`.
   The TOC is built client-side from the article's own headings (toc.js), so
   it adds no content — just navigation derived from what's already on the page. #}
<div class="prose-layout">
  <aside class="toc-aside">
    <nav class="toc" id="toc" aria-label="On this page">
      <p class="toc-title">Contents</p>
    </nav>
  </aside>
  <article class="prose">
{% if image %}
    <img class="prose-hero" src="{{ image }}" alt="{{ imageAlt | default(title) }}" width="1600" height="840" loading="eager">
{% endif %}
{% set titleInContent = "<h1" in content %}
{% set authorInContent = author and (("By " ~ author) in content) %}
{% if not titleInContent %}
    <h1>{{ title }}</h1>
{% endif %}
{% if author and not authorInContent %}
    <p class="prose-meta">
      <span>By {{ author }}</span>
      {# `page.date` is the resolved Date. Front matter `date` may be one of
         Eleventy's directives (e.g. "git Last Modified"), which is still a raw
         string here — only `page.date` has been turned into a real date. #}
      {% if page.date %}<time datetime="{{ page.date | htmlDateString }}">{{ page.date | readableDate }}</time>{% endif %}
      {% if readingTime %}<span>{{ readingTime }} min read</span>{% endif %}
    </p>
{% endif %}
{{ content | safe }}
  </article>
</div>
<script src="/js/toc.js" defer></script>
