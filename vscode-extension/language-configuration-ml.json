{
  "comments": {
    "lineComment": "//"
  },
  "brackets": [["(", ")"]],
  "autoClosingPairs": [
    ["(", ")"],
    ["\"", "\""]
  ],
  "surroundingPairs": [
    ["(", ")"],
    ["\"", "\""]
  ],
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_]*|[0-9]+(?:\\.[0-9]+)?",
  "onEnterRules": [
    {
      "beforeText": "^\\s*(?:.*\\b(?:do|match)|.*(?:=>|=)|(?:effect|handler|module|signature|state|import)\\b.*)\\s*$",
      "action": {
        "indent": "indent"
      }
    }
  ],
  "indentationRules": {
    "increaseIndentPattern": "^\\s*(?:.*\\b(?:do|match)|.*(?:=>|=)|(?:effect|handler|module|signature|state|import)\\b.*)\\s*$",
    "decreaseIndentPattern": "^\\s*(?:end|else)\\b.*$"
  },
  "folding": {
    "markers": {
      "start": "^\\s*//\\s*#region",
      "end": "^\\s*//\\s*#endregion"
    }
  }
}
